<div id="<%= dom_id(photo) %>" style="border: 1px solid #ddd; padding: 12px; border-radius: 8px;">
  <img src="<%= photo.image_url %>" alt="<%= photo.title %>" style="width: 100%; border-radius: 6px;">

  <p style="margin-top: 8px;"><strong><%= photo.photographer %></strong></p>

  <div style="display: flex; justify-content: space-between; align-items: center;">
    <a href="<%= photo.source_url %>" target="_blank" rel="noopener">
      <%= image_tag "icons/links.svg", width: 16 %>
    </a>

    <%= render "likes/button", photo: photo %>
  </div>
</div>